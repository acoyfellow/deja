---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
---

<Base title="API Reference — deja" variant="content">
  <SEO
    slot="head"
    title="API Reference — deja"
    description="deja REST API reference. Base URL, authentication, endpoints, and the JS/TS client."
    keywords="deja api, agent memory api, cloudflare workers, inject, learn"
    path="/docs"
    type="article"
    section="Documentation"
    breadcrumbs={[{ name: 'Docs', path: '/docs' }]}
  />

  <section class="pt-16 pb-12 max-w-2xl">
    <div class="font-mono text-[11px] font-bold tracking-widest uppercase text-brass mb-4">API Reference</div>
    <h1 class="font-serif-sc text-4xl font-bold tracking-tight m-0 mb-4">deja</h1>
    <p class="font-serif font-light text-lg text-chrome-dark m-0">
      HTTP API for persistent agent memory. Two core operations: <code class="text-brass">inject</code> before a task, <code class="text-brass">learn</code> after.
    </p>
  </section>

  {/* ── Setup ───────────────────────────────────────────────── */}
  <section class="mb-12 max-w-2xl">
    <h2 class="font-mono text-xs font-bold tracking-widest uppercase text-brass mb-5">Setup</h2>

    <div class="space-y-4">
      <div>
        <p class="font-mono text-xs text-chrome-dark mb-2">Base URL</p>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-sm text-chrome overflow-x-auto">https://deja-worker.coy.workers.dev</pre>
      </div>

      <div>
        <p class="font-mono text-xs text-chrome-dark mb-2">Authentication — all requests</p>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-sm text-chrome overflow-x-auto">Authorization: Bearer YOUR_API_KEY</pre>
      </div>

      <div>
        <p class="font-mono text-xs text-chrome-dark mb-2">Self-host (optional)</p>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-sm text-chrome-dark leading-relaxed overflow-x-auto">{`git clone https://github.com/acoyfellow/deja
cd deja && bun install
wrangler vectorize create deja-embeddings --dimensions 384 --metric cosine
wrangler secret put API_KEY
wrangler deploy`}</pre>
      </div>
    </div>
  </section>

  {/* ── Core loop ───────────────────────────────────────────── */}
  <section class="mb-12 max-w-2xl">
    <h2 class="font-mono text-xs font-bold tracking-widest uppercase text-brass mb-5">Core loop</h2>

    <div class="space-y-6">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="font-mono text-xs font-bold px-2 py-0.5 bg-brass/20 text-brass rounded">POST</span>
          <code class="font-mono text-sm text-chrome">/inject</code>
          <span class="font-mono text-xs text-chrome-dark">— recall before</span>
        </div>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto">{`curl -X POST https://deja-worker.coy.workers.dev/inject \\
  -H "Authorization: Bearer $API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{"context": "deploying the auth service", "scopes": ["shared"]}'`}</pre>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto mt-2">{`{
  "prompt": "Past learnings:\\n- always run migrations inside a transaction\\n...",
  "learnings": [{ "id": "...", "trigger": "...", "learning": "...", "confidence": 0.9 }]
}`}</pre>
      </div>

      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="font-mono text-xs font-bold px-2 py-0.5 bg-brass/20 text-brass rounded">POST</span>
          <code class="font-mono text-sm text-chrome">/learn</code>
          <span class="font-mono text-xs text-chrome-dark">— store after</span>
        </div>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto">{`curl -X POST https://deja-worker.coy.workers.dev/learn \\
  -H "Authorization: Bearer $API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "trigger": "deploying auth service",
    "learning": "always run migrations inside a transaction",
    "confidence": 0.9,
    "scope": "shared"
  }'`}</pre>
      </div>
    </div>
  </section>

  {/* ── All endpoints ───────────────────────────────────────── */}
  <section class="mb-12 max-w-2xl">
    <h2 class="font-mono text-xs font-bold tracking-widest uppercase text-brass mb-5">All endpoints</h2>

    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-brass/10">
          <th class="font-mono text-xs text-chrome-dark text-left pb-2 pr-4 font-normal">Method</th>
          <th class="font-mono text-xs text-chrome-dark text-left pb-2 pr-4 font-normal">Path</th>
          <th class="font-mono text-xs text-chrome-dark text-left pb-2 font-normal">Description</th>
        </tr>
      </thead>
      <tbody class="font-serif font-light">
        {[
          { method: 'POST', path: '/inject', desc: 'Retrieve context-relevant memories, formatted for prompt injection' },
          { method: 'POST', path: '/learn', desc: 'Store a memory with semantic embedding' },
          { method: 'POST', path: '/query', desc: 'Semantic search — returns raw matches with scores' },
          { method: 'POST', path: '/inject/trace', desc: 'Debug retrieval: full candidate list, scores, threshold pass/fail' },
          { method: 'POST', path: '/run', desc: 'Record a loop run outcome (pass/fail/exhausted). Auto-fires learn.' },
          { method: 'GET',  path: '/runs', desc: 'Run history + convergence stats (mean attempts, trend)' },
          { method: 'GET',  path: '/learnings', desc: 'List memories, optionally filtered by ?scope=' },
          { method: 'GET',  path: '/stats', desc: 'Memory counts by scope' },
          { method: 'GET',  path: '/learning/:id/neighbors', desc: 'Semantically similar memories — use to detect contradictions' },
          { method: 'DELETE', path: '/learning/:id', desc: 'Delete one memory' },
          { method: 'DELETE', path: '/learnings', desc: 'Bulk delete by ?scope=, ?confidence_lt=, ?not_recalled_in_days=' },
        ].map(({ method, path, desc }) => (
          <tr class="border-b border-brass/5">
            <td class="py-2.5 pr-4">
              <span class={`font-mono text-xs px-1.5 py-0.5 rounded ${
                method === 'DELETE' ? 'bg-red-500/10 text-red-400' :
                method === 'GET'    ? 'bg-void-deep text-chrome-dark border border-brass/10' :
                                     'bg-brass/10 text-brass'
              }`}>{method}</span>
            </td>
            <td class="py-2.5 pr-4">
              <code class="font-mono text-xs text-chrome whitespace-nowrap">{path}</code>
            </td>
            <td class="py-2.5 text-chrome-dark text-sm">{desc}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="mt-6 space-y-4">
      <div>
        <p class="font-mono text-xs text-chrome-dark mb-2">POST /learn — body</p>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto">{`{
  "trigger":    "string (required) — when this applies",
  "learning":   "string (required) — what was learned",
  "confidence": 0.9,       // 0–1, default 0.5. Below 0.3 = auto-pruned
  "scope":      "shared",  // "shared" | "agent:<id>" | "session:<id>"
  "reason":     "string",  // optional
  "source":     "string"   // optional
}`}</pre>
      </div>

      <div>
        <p class="font-mono text-xs text-chrome-dark mb-2">POST /inject — body</p>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto">{`{
  "context": "string (required)",
  "scopes":  ["shared"],  // default ["shared"]
  "limit":   5,           // default 5
  "format":  "prompt"     // "prompt" | "learnings"
}`}</pre>
      </div>

      <div>
        <p class="font-mono text-xs text-chrome-dark mb-2">POST /run — body</p>
        <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto">{`{
  "outcome":  "pass",    // "pass" | "fail" | "exhausted"
  "attempts": 3,
  "scope":    "shared",
  "code":     "string",  // optional — stored truncated at 500 chars
  "error":    "string"   // optional — included on fail/exhausted
}`}</pre>
      </div>
    </div>
  </section>

  {/* ── Client library ──────────────────────────────────────── */}
  <section class="mb-12 max-w-2xl">
    <h2 class="font-mono text-xs font-bold tracking-widest uppercase text-brass mb-5">JS / TS client</h2>

    <div class="space-y-4">
      <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-sm text-chrome-dark overflow-x-auto">npm install deja-client</pre>

      <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto">{`import deja from 'deja-client'

const mem = deja('https://deja-worker.coy.workers.dev', { apiKey: process.env.API_KEY })

// before a task
const { learnings } = await mem.inject('deploying auth service')

// after a task
await mem.learn('deploying auth service', 'always run migrations in a transaction')

// track loop convergence
await mem.recordRun('pass', 3, { scope: 'shared', code: '...' })
const { stats } = await mem.getRuns({ scope: 'shared' })
// stats.trend → 'improving' | 'regressing' | 'stable'`}</pre>
    </div>
  </section>

  {/* ── MCP ─────────────────────────────────────────────────── */}
  <section class="mb-16 max-w-2xl">
    <h2 class="font-mono text-xs font-bold tracking-widest uppercase text-brass mb-5">MCP</h2>

    <p class="font-serif font-light text-chrome-dark mb-4">
      deja exposes all endpoints as MCP tools at <code class="text-brass">/mcp</code>. Works with Claude Code, Continue, Cursor, Cline, and any client that supports streamable HTTP MCP.
    </p>

    <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto mb-4">{`# Claude Code
claude mcp add --transport http deja https://deja-worker.coy.workers.dev/mcp \\
  --header "Authorization: Bearer $API_KEY"`}</pre>

    <pre class="bg-void-deep border border-brass/10 rounded-sm px-4 py-3 font-mono text-xs text-chrome-dark leading-relaxed overflow-x-auto">{`# Generic MCP config
{
  "mcpServers": {
    "deja": {
      "type": "http",
      "url": "https://deja-worker.coy.workers.dev/mcp",
      "headers": { "Authorization": "Bearer YOUR_API_KEY" }
    }
  }
}`}</pre>

    <p class="font-mono text-xs text-chrome-dark mt-4">
      Available tools: <code class="text-brass">learn</code>, <code class="text-brass">inject</code>, <code class="text-brass">inject_trace</code>, <code class="text-brass">query</code>, <code class="text-brass">forget</code>, <code class="text-brass">forget_bulk</code>, <code class="text-brass">list</code>, <code class="text-brass">stats</code>, <code class="text-brass">record_run</code>, <code class="text-brass">get_runs</code>
    </p>
  </section>
</Base>
