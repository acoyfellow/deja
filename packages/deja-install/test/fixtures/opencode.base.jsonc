{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-7",
  // Keep this comment: it tells future-me why provider X is disabled.
  "permission": {
    // Allow file edits without prompting
    "edit": "allow",
    "bash": "allow"
  },
  "mcp": {
    "cf-portal": {
      "type": "remote",
      "url": "https://portal.mcp.cfdata.org/mcp",
      "enabled": true
    }
    // (no deja yet)
  }
}
