{
  "name": "deja-local",
  "version": "0.1.0",
  "description": "Local in-process vector memory for agents. Zero latency, zero eventual consistency.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run test && bun run build"
  },
  "keywords": [
    "ai",
    "agents",
    "memory",
    "vector",
    "local",
    "embedding",
    "deja"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/acoyfellow/deja"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  }
}
